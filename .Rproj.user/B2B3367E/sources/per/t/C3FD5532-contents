```{r inflation reg full sample levels, cache = T}

library(stargazer)
library(sandwich)

for(i in c(1,4,12)){
  inflation_lead  <- dplyr::lead(
    zoo::rollmean(US_data$inflation_month, k = i, align = "right", fill = NA), 
    i)
  
  assign(paste0("infla_fcst",i), value = lm(inflation_lead ~ EUR_CDS +
                      Debt_growth, data = US_data))
  fitted_fcst     <- 
    get(paste0("infla_fcst",i))$coefficients[2] * US_data$EUR_CDS +
    get(paste0("infla_fcst",i))$coefficients[3] * US_data$Debt_growth
  
  assign(paste0("lm5_",i), 
         value = lm(ILSBEI5 ~ EUR_CDS + Debt_growth, data = US_data))
  assign(paste0("lm5_bis",i), 
         value = lm(ILSBEI5 ~ fitted_fcst, data = US_data))
         
