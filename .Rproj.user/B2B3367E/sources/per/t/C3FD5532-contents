fct_moments <- function(theta, total_data, return_res = F){
  
  Instrument    <- total_data$instrument
  Lhs_var       <- total_data$lhs
  Interest_var  <- total_data$interest
  Controls      <- as.matrix(total_data$controls)
  
  # First step regression
  b1 <- theta[1]
  res1 <- Interest_var  - b1 * Instrument
  
  # Orthogonalizing the regressors
  l_theta <- 1
  beta1   <- theta[(l_theta + 1):(l_theta + ncol(Controls))]
  l_theta <- l_theta + ncol(Controls)
  res2    <- Controls -
    matrix(Instrument, ncol = 1) %*% matrix(beta1, nrow = 1)
  
  # Second stage reg
  beta2         <- theta[(l_theta + 1):(l_theta + ncol(Controls))]
  l_theta       <- l_theta + ncol(Controls)
  beta_interest <- theta[l_theta + 1]
  
  fitted_step1  <- b1 * Instrument
  res3          <- Lhs_var - beta_interest * fitted_step1 -
    res2 %*% matrix(beta2, ncol = 1)
  ortho_res3    <- (res3 %*% matrix(1, nrow = 1, ncol = ncol(Controls) + 1)) * cbind(
    fitted_step1, res2
  )
  
  if(return_res == F){
    return(
      cbind(
        res1 * Instrument, 
        res2 * (matrix(Instrument, ncol = 1) %*% matrix(1, nrow = 1, ncol = length(beta1))), 
        ortho_res3
      )
    )  
  }else{
    return(
      list(res3,
           "R2_first" = round(1 - sum(res1^2)/sum(Interest_var^2),3),
           "R2_second" = round(1 - sum(res3^2)/sum(Lhs_var^2),3))
    )
  }
  
}


