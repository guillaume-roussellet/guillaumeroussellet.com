#### GMM with skew

We consider the following model: $$
    \Delta^k\mathrm{ILSBEI}_t(n) = \alpha_n + \beta_n \times \Delta^k\mathrm{PD}_t+\varepsilon_t(n)\,,
$$ and we assume that the PD is incorrectly measured by the 5y CDS, such
that: $$
  \mathrm{CDS}_t = \mathrm{PD}_t + \eta_t\,,
$$ where $\eta_t$ has mean $a$ such that the CDS is an biased measure of
the PD. We can think about $\eta_t$ as pure measurement error or a
risk-premium, or both.

For simplicity, we denote by $y_t$ the ILSBEI, $x_t$ the CDS and $X_t$
the PD. The usual OLS (biased) estimator is based on the following
moment conditions: $$
  \begin{array}{rcl}
    \mathbb{E}\left(x_t \right) &=& \mathbb{E}\left(X_t \right) + a\\
    \mathbb{E}\left(y_t \right) &=& \alpha + \beta\, \mathbb{E}\left(X_t \right) \\
    \mathbb{E}\left(x_t^2 \right) &=& \mathbb{E}\left(X_t^2 \right) + 2a\mathbb{E}\left(X_t \right)+\sigma_\eta^2 + a^2 \\
    \mathbb{E}\left(y_t^2 \right) &=& \alpha^2 + \beta^2\mathbb{E}\left(X_t^2 \right)+\sigma_\varepsilon^2+2\alpha\beta\,\mathbb{E}\left(X_t \right)\\
    \mathbb{E}\left(x_ty_t \right) &=& \alpha\,\mathbb{E}\left(X_t + a \right)+\beta\,\left[\mathbb{E}\left(X_t^2 \right)+a\mathbb{E}\left(X_t \right)\right]
  \end{array}
$$ Or, using the notation
$\mu_{X}^{(i)} := \mathbb{E}\left(X_t^i \right)$: $$
  \begin{array}{rcl}
    \mathbb{E}\left(x_t \right) &=& \mu_{X}^{(1)} + a\\
    \mathbb{E}\left(y_t \right) &=& \alpha + \beta\, \mu_{X}^{(1)} \\
    \mathbb{E}\left(x_t^2 \right) &=& \mu_{X}^{(2)} + 2a\,\mu_{X}^{(1)}+\sigma_\eta^2 + a^2 \\
    \mathbb{E}\left(y_t^2 \right) &=& \alpha^2 + \beta^2\mu_{X}^{(2)}+\sigma_\varepsilon^2+2\alpha\beta\,\mu_{X}^{(1)}\\
    \mathbb{E}\left(x_ty_t \right) &=& \alpha a + (\alpha+\beta a)\mu_{X}^{(1)} + \beta \mu_{X}^{(2)}
  \end{array}
$$ There are 7 unknowns on the right-hand side:
$\{\alpha, \beta,\sigma_\eta,\sigma_\varepsilon,a, \mu_X^{(1)}, \mu_X^{(2)}\}$.
However, there are only 5 estimating equations. We add third-order
moments: $$
  \begin{array}{rcl}
    \mathbb{E}\left(x_t^3 \right)  &=& \mu_X^{(3)}  + 3a\mu_X^{(2)}+3(\sigma_\eta^2 + a^2)\mu_X^{(1)} + a^3 + \mathcal{S}_\eta+3a\sigma_\eta^2\\
    \mathbb{E}\left(y_t^3 \right)  &=& \alpha^3 + 3 \alpha^2\beta\mu_X^{(1)} + 3\alpha\beta^2\mu_X^{(2)} + \beta^3\mu_X^{(3)} + 3\left(\alpha + \beta\mu_X^{(1)}\right)\sigma_\varepsilon^2+ \mathcal{S}_\varepsilon\\
    \mathbb{E}\left(x_t^2y_t \right)  &=& \left(\alpha+\beta\mu_X^{(1)}\right)\left(a^2 + \sigma_\eta^2\right)+2a\left(\alpha \mu_X^{(1)} + \beta\mu_X^{(2)}\right)+\alpha \mu_X^{(2)} + \beta \mu_X^{(3)}\\
    \mathbb{E}\left(x_ty_t^2 \right)  &=& \sigma_\varepsilon^2\left(\mu_X^{(1)} + a\right)+a\left(\alpha^2+ 2\alpha\beta\mu_X^{(1)} + \beta^2\mu_X^{(2)}\right) + \alpha^2\mu_X^{(1)} + 2\alpha\beta\mu_X^{(2)} + \beta^2\mu_X^{(3)}
  \end{array}
$$ The case of Geary (1942) can be found by assuming $a=0$, and that the
residuals are symmetric. Here, notice that we still do not achieve
identification because the above equations add three unknown skewness
parameters:
$\{\mu_X^{(3)},\,\mathcal{S}_\varepsilon,\, \mathcal{S}_\eta\}$. Since
$a$ does not seem to be identified, we suppress it from the above
equations. We end up with the following just-identified moment system:
$$
  \begin{array}{rcl}
    \mathbb{E}\left(x_t \right) &=& \mu_{X}^{(1)} \\
    \mathbb{E}\left(y_t \right) &=& \alpha + \beta\, \mu_{X}^{(1)} \\
    \mathbb{E}\left(x_t^2 \right) &=& \mu_{X}^{(2)} + \sigma_\eta^2 \\
    \mathbb{E}\left(y_t^2 \right) &=& \alpha^2 + \beta^2\mu_{X}^{(2)} +2\alpha\beta\,\mu_{X}^{(1)} +\sigma_\varepsilon^2\\
    \mathbb{E}\left(x_ty_t \right) &=&  \alpha\mu_{X}^{(1)} + \beta \mu_{X}^{(2)}\\
     \mathbb{E}\left(x_t^3 \right)  &=& \mu_X^{(3)}  +3\sigma_\eta^2 \mu_X^{(1)} + \mathcal{S}_\eta\\
    \mathbb{E}\left(y_t^3 \right)  &=& \alpha^3 + 3 \alpha^2\beta\mu_X^{(1)} + 3\alpha\beta^2\mu_X^{(2)} + \beta^3\mu_X^{(3)} + 3\left(\alpha + \beta\mu_X^{(1)}\right)\sigma_\varepsilon^2+ \mathcal{S}_\varepsilon\\
    \mathbb{E}\left(x_t^2y_t \right)  &=& \left(\alpha+\beta\mu_X^{(1)}\right) \sigma_\eta^2 +\alpha \mu_X^{(2)} + \beta \mu_X^{(3)}\\
    \mathbb{E}\left(x_ty_t^2 \right)  &=& \sigma_\varepsilon^2 \mu_X^{(1)}  + \alpha^2\mu_X^{(1)} + 2\alpha\beta\mu_X^{(2)} + \beta^2\mu_X^{(3)}
  \end{array}
$$

Deameaning the variables, we have: $$
  \begin{array}{rcl}
    \mathbb{E}\left(x_t^2 \right) &=& \mu_{X}^{(2)} + \sigma_\eta^2 \\
    \mathbb{E}\left(y_t^2 \right) &=& \beta^2\mu_{X}^{(2)} +\sigma_\varepsilon^2\\
    \mathbb{E}\left(x_ty_t \right) &=&  \beta \mu_{X}^{(2)}\\
     \mathbb{E}\left(x_t^3 \right)  &=& \mu_X^{(3)}   + \mathcal{S}_\eta\\
    \mathbb{E}\left(y_t^3 \right)  &=&  \beta^3\mu_X^{(3)} + \mathcal{S}_\varepsilon\\
    \mathbb{E}\left(x_t^2y_t \right)  &=& \beta \mu_X^{(3)}\\
    \mathbb{E}\left(x_ty_t^2 \right)  &=& \beta^2\mu_X^{(3)}
  \end{array}
$$ This leads to a just-identified system where the estimate for $\beta$
is given by: $$
  \widehat{\beta} = \frac{\sum_{t=1}^{T} x_ty_t^2}{\sum_{t=1}^{T}x_t^2 y_t}\,.
$$

All the following are estimated with one-step GMM (weighting is
irrelevant in a just-identified system) and HAC-corrected standard
deviations.

```{r GMM estimation, cache = T}
library(gmm)
theta_to_params <- function(params, exponen = T){
  
  alpha   <- 0#params[1]
  beta    <- params[1]
  mu_x_1  <- 0#params[3]
  mu_x_2  <- params[2]
  mu_x_3  <- params[3]/1000
  
  sigma_eta <- params[4]
  sigma_eps <- params[5]
  a <- 0 #params[8]
  skew_eps <- params[6]/1000
  skew_eta <- params[7]/1000
  
  if(exponen == T){
    mu_x_2    <- exp(params[2])
    sigma_eta <- exp(params[4])
    sigma_eps   <- exp(params[5])
  }
  
  return(list(
    "alpha" = alpha,
    "beta" = beta,
    "mu_x_1" = mu_x_1,
    "mu_x_2" = mu_x_2,
    "mu_x_3" = mu_x_3,
    "sigma_eta" = sigma_eta,
    "sigma_eps" = sigma_eps,
    "a" = a,
    "skew_eps" = skew_eps,
    "skew_eta" = skew_eta
  ))
}

GMM_fun <- function(params, total_data, exponen = T){
  
  X_data <- total_data[,1] 
  Y_data <- total_data[,2] 
  
  get_params <- theta_to_params(params, exponen)
  
  alpha     <- get_params$alpha
  beta      <- get_params$beta
  mu_x_1    <- get_params$mu_x_1
  mu_x_2    <- get_params$mu_x_2
  mu_x_3    <- get_params$mu_x_3
  
  sigma_eta <- get_params$sigma_eta
  sigma_eps <- get_params$sigma_eps
  a         <- get_params$a
  skew_eps  <- get_params$skew_eps
  skew_eta  <- get_params$skew_eta
  
  
  m1 <- X_data - (mu_x_1 + a)
  m2 <- Y_data - (alpha + beta * mu_x_1)
  m3 <- X_data^2 - (mu_x_2 + 2 * a * mu_x_1 + sigma_eta^2 + a^2)
  m4 <- Y_data^2 - (alpha^2 + beta^2  * mu_x_2 + sigma_eps^2 + 2 * alpha * beta * mu_x_1)
  m5 <- Y_data * X_data - (alpha * a + (alpha + beta * a) * mu_x_1 + beta * mu_x_2)
  
  m6 <- X_data^3 - (
    mu_x_3 + 3 * a * mu_x_2 + 3 * (sigma_eta^2 + a^2) * mu_x_1 + a^3 + 3 * a * sigma_eta^2 + skew_eta
  )
  m7 <- Y_data^3 - (
    alpha^3 + 3 * alpha^2 * beta * mu_x_1 + 3 * alpha * beta^2 * mu_x_2 + beta^3 * mu_x_3 + 3 * (alpha + beta * mu_x_1) * sigma_eps^2 + skew_eps
  )
  m8 <- X_data^2 * Y_data - (
    (alpha + beta * mu_x_1) * (a^2 + sigma_eta^2) + 2 * a * (alpha * mu_x_1 + beta * mu_x_2) + alpha * mu_x_2 + beta * mu_x_3
  )
  m9 <- X_data * Y_data^2 - (
    sigma_eps^2 * (mu_x_1 + a) + a * (alpha^2 + 2 * alpha * beta * mu_x_1 + beta^2 * mu_x_2) + alpha^2 * mu_x_1 + 2 * alpha * beta * mu_x_2 + beta^2 * mu_x_3
  )
  
  moment_matrix <-  1e4 * cbind(#m1,m2,
                                m3,m4,m5,m6,m7,m8,m9)
  return(moment_matrix)
  
}

estim_fun <- function(params, total_data, exponen){
    moment_mat <- GMM_fun(params, total_data, exponen)
    
    result <- apply(moment_mat, 2, mean)
    result <- crossprod(result)
    
    return(c(result))
}




