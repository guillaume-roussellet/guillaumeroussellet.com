library(gmm)

ILSBEI_data <- reduced_US_data_IV %>% dplyr::select(ILSBEI2, ILSBEI3, ILSBEI5, ILSBEI7, ILSBEI10) %>% as.matrix()

count <- 0
for(i in c(2,3,5,7,10)){
  count <- count + 1
  moment_data <- list(
    "instrument" = reduced_US_data_IV$Debt_growth_yoy - mean(reduced_US_data_IV$Debt_growth_yoy),
    "lhs" = ILSBEI_data[, count] - mean(ILSBEI_data[, count]),
    "interest" = reduced_US_data_IV$EUR_CDS - mean(reduced_US_data_IV$EUR_CDS),
    "controls" = as.matrix(reduced_US_data_IV[,c("vix","libor_ois", "hpw_noise", "tips_noise", "Off_On_run")]) - matrix(1, nrow(reduced_US_data_IV), 1) %*% apply(as.matrix(reduced_US_data_IV[,c("vix","libor_ois", "hpw_noise", "tips_noise", "Off_On_run")]),2,mean)
  )  
  
  
  lm_first        <- lm(moment_data$interest ~ moment_data$instrument, data = US_data)
  lm_vix          <- lm(moment_data$controls[,1] ~ moment_data$instrument, data = US_data)
  lm_libor_ois    <- lm(moment_data$controls[,2] ~ moment_data$instrument, data = US_data)
  lm_hpw_noise    <- lm(moment_data$controls[,3] ~ moment_data$instrument, data = US_data)
  lm_tips_noise   <- lm(moment_data$controls[,4] ~ moment_data$instrument, data = US_data)
  lm_Off_On_run   <- lm(moment_data$controls[,5] ~ moment_data$instrument, data = US_data)
  lm_second       <- lm(moment_data$lhs ~ lm_vix$residuals +
                          lm_libor_ois$residuals + lm_hpw_noise$residuals + 
                          lm_tips_noise$residuals + lm_Off_On_run$residuals +
                          lm_first$fitted)
  
  params_init <- c(
    lm_first$coefficients[2],
    lm_vix$coefficients[2],
    lm_libor_ois$coefficients[2],
    lm_hpw_noise$coefficients[2],
    lm_tips_noise$coefficients[2],
    lm_Off_On_run$coefficients[2],
    lm_second$coefficients[2:7]
  )
  
  names(params_init) <- c(
    "CDS: Instrument",
    "vix: Instrument",
    "libor_ois: Instrument",
    "hpw_noise: Instrument",
    "tips_noise: Instrument",
    "Off_On_run: Instrument",
    "residual vix",
    "residual libor_ois",
    "residual hpw_noise",
    "residual tips_noise",
    "residual Off_On_run",
    "fitted CDS"
  )
  
  assign(x = paste0("gmm_IV",i), value = gmm(g = fct_moments, x=moment_data, t0 = params_init, 
