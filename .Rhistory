kappa_0,
kappa_pd,
RR,
RR_real),
yield_EH = compute_yields_EH(maturities, type, risk, default, theta_d,
kappa_d,
M_bar,
PD,
kappa_0,
kappa_pd,
RR,
RR_real))
total_params <- total_params %>% group_by(maturities, default) %>%
mutate(ILS = yield[type == "Nominal" & risk == "Riskfree"] -
yield[type == "Real" & risk == "Riskfree"],
BEI = yield[type == "Nominal" & risk == "Defaultable"] -
yield[type == "Real" & risk == "Defaultable"],
ILS_EH = yield_EH[type == "Nominal" & risk == "Riskfree"] -
yield_EH[type == "Real" & risk == "Riskfree"],
BEI_EH = yield_EH[type == "Nominal" & risk == "Defaultable"] -
yield_EH[type == "Real" & risk == "Defaultable"]) %>%
mutate(ILSBEI = ILS-BEI,
ILSBEI_EH = ILS_EH - BEI_EH)
ggplot(total_params %>% filter(type == "Nominal", risk == "Riskfree", default == "Absorbing")) +
geom_line(aes(x = maturities, y = yield*100)) +
geom_line(aes(x = maturities, y = yield_EH*100), col = "red")
compute_yields_EH <- function(n, type, risk, default, theta_d,
kappa_d,
M_bar,
PD,
kappa_0,
kappa_pd,
RR,
RR_real){
if(default == "Independent"){
if(risk == "Riskfree"){
if(type == "Nominal"){
yield <- - M_bar + kappa_0 + kappa_pd * PD - log((1 + PD * (exp(theta_d) - 1))) + PD * (1 - exp(-kappa_d))
} else if (type == "Real"){
yield <- - M_bar - log((1 + PD * (exp(theta_d) - 1)))
}
} else if(risk == "Defaultable"){
if(type == "Nominal"){
yield <- - M_bar + kappa_0 + kappa_pd * PD - log((1 + PD * (exp(theta_d) - 1))) + PD * (1 - exp(-kappa_d)) +
PD * (1 - RR_real) + PD * (exp(-kappa_d) * (1-RR) - (1-RR_real))
} else if (type == "Real"){
yield <- - M_bar - log((1 + PD * (exp(theta_d) - 1))) + PD * (1 - RR_real)
}
}
} else if (default == "Absorbing"){
if(risk == "Riskfree"){
if(type == "Nominal"){
price1_adjust <- exp(M_bar) * (1 + PD * (exp(theta_d) - 1)) * exp(-kappa_0 - kappa_pd * PD)
price1  <- price1_adjust * (1 + PD * (exp(-kappa_d) - 1))
price   <- price1
if(n>1){
for (i in 2:n){
price <- price1_adjust * (
PD * exp((i-1) * (M_bar - kappa_0 - kappa_pd + theta_d )- i*kappa_d)+
(1-PD) * price)
}
}
yield <- - 1/n * log(price)
} else if (type == "Real"){
price1  <- exp(M_bar) * (1 + PD * (exp(theta_d) - 1))
price   <- price1
if(n>1){
for (i in 2:n){
price <- price1 * (PD * exp((i - 1) * (M_bar + theta_d))+
(1-PD) * price)
}
}
yield <- - 1/n * log(price)
}
} else if(risk == "Defaultable"){
if(type == "Nominal"){
price1_adjust <- exp(M_bar) * (1 + PD * (exp(theta_d) - 1)) * exp(-kappa_0 - kappa_pd * PD)
price1  <- price1_adjust * (1 - PD * (1 - exp(-kappa_d) * RR))
price   <- price1
if(n>1){
for (i in 2:n){
price <- price1_adjust * (
PD * exp((i-1) * (M_bar - kappa_0 - kappa_pd + theta_d )- i*kappa_d) * RR^i +
(1-PD) * price)
}
}
yield <- - 1/n * log(price)
} else if (type == "Real"){
price1_adjust <- exp(M_bar) * (1 + PD * (exp(theta_d) - 1))
price1  <- price1_adjust * (1 - PD *(1-RR_real))
price   <- price1
if(n>1){
for (i in 2:n){
price <- price1_adjust * (PD * exp((i-1) * (M_bar + theta_d)) * RR_real^i +
(1-PD) * price)
}
}
yield <- - 1/n * log(price)
}
}
}
return(yield)
}
total_params <- expand.grid(maturities = maturities,
type = type,
risk = risk,
default = default,
theta_d = theta_d,
kappa_d = kappa_d,
M_bar = M_bar,
PD = PD,
kappa_0 = kappa_0,
kappa_pd = kappa_pd,
RR = RR,
RR_real = RR_real)
total_params <- total_params %>% group_by(maturities, type, risk, default) %>%
mutate(yield = compute_yields(maturities, type, risk, default, theta_d,
kappa_d,
M_bar,
PD,
kappa_0,
kappa_pd,
RR,
RR_real),
yield_EH = compute_yields_EH(maturities, type, risk, default, theta_d,
kappa_d,
M_bar,
PD,
kappa_0,
kappa_pd,
RR,
RR_real))
